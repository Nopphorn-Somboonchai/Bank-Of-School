rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. ฟังก์ชันตรวจสอบการเข้าสู่ระบบทั่วไป (Authentication Check)
    function isAuthenticated() {
      return request.auth != null;
    }

    // 2. ฟังก์ชันตรวจสอบสิทธิ์ความเป็นครู (Teacher Role Check)
    // เช็คว่ามีเอกสารข้อมูลครูอยู่ในระบบภายใต้ appId (โรงเรียน) นั้น ๆ หรือไม่
    function isTeacher(appId) {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/artifacts/$(appId)/users/$(request.auth.uid));
    }

    // Fallback: ปิดกั้นการเข้าถึงที่ไม่ได้ระบุไว้ในเงื่อนไขอย่างชัดเจน (ป้องกันบุคคลภายนอกเข้าถึงข้อมูลทุกส่วน)
    match /{document=**} {
      allow read, write: if false;
    }

    // กฎการเข้าถึงข้อมูลตามโครงการ Bank of School (Multi-tenant โดยใช้ appId)
    match /artifacts/{appId} {
      
      // ==========================================
      // 1. ข้อมูลคุณครู / เจ้าหน้าที่ระบบ (Users)
      // ==========================================
      match /users/{userId} {
        // อนุญาตให้อ่านข้อมูลครูคนอื่นในโรงเรียนเดียวกันได้ หรืออ่านข้อมูลตัวเอง
        allow read: if isAuthenticated() && (request.auth.uid == userId || isTeacher(appId));
        // อนุญาตให้คุณครูสร้างข้อมูลตัวเองได้ตอนสมัครใช้งานครั้งแรก
        allow create: if isAuthenticated() && request.auth.uid == userId;
        // อนุญาตให้แก้ไขข้อมูลเฉพาะของตัวเองเท่านั้น
        allow update: if isAuthenticated() && request.auth.uid == userId;
        // ไม่อนุญาตให้ลบบัญชีผู้ใช้โดยตรง เพื่อป้องกันข้อมูลผู้สร้างธุรกรรมสูญหาย (No-Delete)
        allow delete: if false;
      }
      
      // ==========================================
      // 2. ข้อมูลโปรไฟล์นักเรียน (Students)
      // ==========================================
      match /students/{studentId} {
        // นโยบาย No-Delete: อนุญาตให้ครู อ่าน สร้าง และแก้ไขข้อมูลนักเรียนได้เท่านั้น (ห้ามลบเด็ดขาด)
        allow read, create, update: if isTeacher(appId);
        allow delete: if false;
      }
      
      // ==========================================
      // 3. บัญชีเงินฝากนักเรียน (Accounts)
      // ==========================================
      match /accounts/{accountId} {
        allow read: if isTeacher(appId);
        // นโยบาย No-Delete และป้องกันยอดเงินคงเหลือติดลบจากฝั่งเซิร์ฟเวอร์ (currentBalance >= 0)
        allow create, update: if isTeacher(appId) && 
          request.resource.data.currentBalance >= 0;
        allow delete: if false;
      }
      
      // ==========================================
      // 4. รายการธุรกรรมการเงิน (Transactions)
      // ==========================================
      match /transactions/{transactionId} {
        // นโยบาย Append-only: คุณครูสามารถดูลายรายการธุรกรรม (Read) และบันทึกธุรกรรมใหม่ (Create) ได้เท่านั้น (ห้ามแก้ไขและห้ามลบเด็ดขาด)
        // และป้องกันยอดเงินติดลบของรายการย้อนหลังจากฝั่งเซิร์ฟเวอร์ (balanceAfter >= 0)
        allow read: if isTeacher(appId);
        allow create: if isTeacher(appId) && 
          request.resource.data.amount > 0 && 
          request.resource.data.balanceAfter >= 0;
        allow update, delete: if false;
      }
      
      // ==========================================
      // 5. บันทึกประวัติการใช้งานระบบ (Audit Logs)
      // ==========================================
      match /audit_logs/{logId} {
        // นโยบาย Append-only: อนุญาตให้คุณครูอ่านและบันทึกประวัติการใช้งานระบบได้เท่านั้น (ห้ามแก้ไขหรือลบเด็ดขาด)
        allow read, create: if isTeacher(appId);
        allow update, delete: if false;
      }
      
      // ==========================================
      // 6. การตั้งค่าระบบ (Settings)
      // ==========================================
      match /settings/{settingId} {
        // คุณครูสามารถอ่านและแก้ไขการตั้งค่าระบบได้
        allow read, write: if isTeacher(appId);
      }
      
      // ==========================================
      // 7. รายงานผลสรุปการเงิน (Reports)
      // ==========================================
      match /reports/{reportId} {
        // คุณครูเท่านั้นที่สามารถเข้าถึงรายงานได้
        allow read, write: if isTeacher(appId);
      }
      
      // ==========================================
      // 8. ตัวนับรหัสรันนิ่งอ้างอิงธุรกรรม (Counter)
      // ==========================================
      match /counter/{counterId} {
        // คุณครูเท่านั้นที่ดึงและเพิ่มยอดตัวนับได้
        allow read, write: if isTeacher(appId);
      }
    }
  }
}